<UserControl x:Class="WpfMusicPlayer.Views.PlaylistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfMusicPlayer.ViewModels"
             PreviewMouseLeftButtonDown="PlaylistView_PreviewMouseLeftButtonDown">
    <UserControl.Resources>
        <Style x:Key="PlaylistScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="#40FFFFFF" CornerRadius="3" Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#60FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#80FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlaylistScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource PlaylistScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlaylistScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       HorizontalAlignment="Right"
                                       Orientation="Vertical"
                                       Style="{StaticResource PlaylistScrollBarStyle}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="20,10,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Width="80" Height="80" CornerRadius="8" Background="#444444" ClipToBounds="True"
                    Cursor="Hand" MouseLeftButtonUp="CoverBorder_MouseLeftButtonUp"
                    ToolTip="点击更换封面">
                <Grid>
                    <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                               Foreground="#666666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Image Source="{Binding PlaylistCoverImage}" Stretch="UniformToFill"/>
                    <!-- 悬浮遮罩 -->
                    <Border x:Name="CoverOverlay" Background="#60000000" Opacity="0">
                        <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CoverOverlay" 
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CoverOverlay" 
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
                <!-- 播放列表标题：点击可编辑 -->
                <Grid>
                    <TextBlock x:Name="PlaylistTitleBlock"
                               Text="{Binding PlaylistTitle}" FontSize="20" FontWeight="Bold" Foreground="White"
                               Cursor="Hand" ToolTip="点击修改标题"
                               MouseLeftButtonUp="PlaylistTitleBlock_MouseLeftButtonUp"/>
                    <TextBox x:Name="PlaylistTitleEdit"
                             Text="{Binding PlaylistTitle, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="20" FontWeight="Bold" Foreground="White"
                             Background="#333333" BorderBrush="#0078D7" BorderThickness="0,0,0,2"
                             CaretBrush="White" Padding="2,0"
                             Visibility="Collapsed"
                             LostFocus="PlaylistTitleEdit_LostFocus"
                             KeyDown="PlaylistTitleEdit_KeyDown"/>
                </Grid>
                <TextBlock Foreground="#BBBBBB" FontSize="13" Margin="0,4,0,0"
                           Text="{Binding PlaylistItems.Count, StringFormat='共 {0} 首歌曲'}"/>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="15,0,0,0" Orientation="Horizontal">

                <Button Content="&#xE8F4;" FontFamily="Segoe MDL2 Assets"
                        Command="{Binding CreatePlaylistCommand}"
                        FontSize="16" Foreground="White" Background="#444444" Padding="15,8" BorderThickness="0" Cursor="Hand" Margin="0,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="&#xE838;" FontFamily="Segoe MDL2 Assets"
                        Command="{Binding OpenPlaylistCommand}"
                        FontSize="16" Foreground="White" Background="#444444" Padding="15,8" BorderThickness="0" Cursor="Hand" Margin="15,0,0,0" >
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="&#xEA35;" FontFamily="Segoe MDL2 Assets"
                        Command="{Binding SavePlaylistCommand}"
                        FontSize="16" Foreground="White" Background="#444444" Padding="15,8" BorderThickness="0" Cursor="Hand" Margin="15,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Style="{StaticResource PlaylistScrollViewerStyle}">
            <ListBox x:Name="PlaylistListBox"
                     ItemsSource="{Binding PlaylistItems}"
                     AlternationCount="2"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                     PreviewMouseWheel="PlaylistListBox_OnPreviewMouseWheel"
                     PreviewMouseLeftButtonUp="PlaylistListBox_PreviewMouseLeftButtonUp">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <ContextMenu.Template>
                            <ControlTemplate TargetType="ContextMenu">
                                <Border Background="#2D2D2D" BorderBrush="#444444" BorderThickness="1"
                                        CornerRadius="4" Padding="0,4">
                                    <StackPanel IsItemsHost="True"/>
                                </Border>
                            </ControlTemplate>
                        </ContextMenu.Template>
                        <ContextMenu.Resources>
                            <Style TargetType="MenuItem">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="MenuItem">
                                            <Border x:Name="Bd" Background="Transparent" Padding="10,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <ContentPresenter ContentSource="Icon" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <ContentPresenter ContentSource="Header" VerticalAlignment="Center"
                                                                      TextBlock.Foreground="{TemplateBinding Foreground}"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3D3D3D"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ContextMenu.Resources>
                        <MenuItem Header="添加歌曲" Command="{Binding AddSongToPlaylistCommand}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="删除歌曲"
                                  Command="{Binding RemoveSongFromPlaylistCommand}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="20,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Padding="{TemplateBinding Padding}" Background="#10FFFFFF">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                            <Setter TargetName="Bd" Property="Background" Value="#18FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#300078D7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PlaylistItemViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="4"
                                    Background="#444444" ClipToBounds="True" Margin="0,0,12,0">
                                <Grid>
                                    <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               Foreground="#666666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Image Source="{Binding AlbumCover}" Stretch="UniformToFill"/>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="{Binding Title}" FontSize="14" TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                    <Setter Property="Foreground" Value="#0078D7"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Artist}" Foreground="#999999" FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="&#xE7F6; " FontFamily="Segoe MDL2 Assets" Foreground="#999999" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PlayedCount}"
                                           Foreground="#999999" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
    </Grid>
</UserControl>
