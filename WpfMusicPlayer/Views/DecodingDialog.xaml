<Window x:Class="WpfMusicPlayer.Views.DecodingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="解码中"
        Width="320" Height="130"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Border Background="#E6202020" CornerRadius="10" BorderBrush="#40FFFFFF" BorderThickness="1" Padding="24,20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="网易云加密格式解码中，请等待..." Foreground="White" FontSize="16"
                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <ProgressBar IsIndeterminate="True" Height="6"
                         Background="#40FFFFFF" Foreground="#0078D7" BorderThickness="0"/>
        </StackPanel>
    </Border>
</Window>
