<Window x:Class="WpfMusicPlayer.Helpers.OffsetAdjustDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        SizeToContent="WidthAndHeight"
        MinWidth="450"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        PreviewKeyDown="OffsetAdjustDialog_OnPreviewKeyDown">

    <Window.Resources>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="StepButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Regular"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Border Margin="24" CornerRadius="8" Background="#E6202020"
            BorderBrush="#40FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Direction="270" Color="Black" Opacity="0.6"/>
        </Border.Effect>

        <Grid MinHeight="160">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="24,12,24,12">
                <TextBlock x:Name="TitleText"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Left"
                           Margin="0,0,0,16"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource StepButtonStyle}"
                            Content="−"
                            Click="DecreaseButton_Click"/>

                    <Border Grid.Column="1" Margin="8,0"
                            Background="#30FFFFFF"
                            BorderBrush="#40FFFFFF"
                            BorderThickness="1">
                        <Grid>
                            <TextBox x:Name="ValueTextBox"
                                     FontSize="16"
                                     FontWeight="SemiBold"
                                     Foreground="White"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     TextAlignment="Center"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Stretch"
                                     Padding="0,6"
                                     CaretBrush="White"
                                     SelectionBrush="#400078D7"
                                     LostFocus="ValueTextBox_LostFocus"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="2"
                            Style="{StaticResource StepButtonStyle}"
                            Content="+"
                            Click="IncreaseButton_Click"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                    <TextBlock Text="快速调整(ms)" FontSize="14" Foreground="#88FFFFFF" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <Button Click="QuickStep_Click" Content="-500" Style="{StaticResource StepButtonStyle}" Tag="-500"/>
                    <Button Click="QuickStep_Click" Content="-100" Style="{StaticResource StepButtonStyle}" Tag="-100"/>
                    <Button Click="QuickStep_Click" Content="+100" Style="{StaticResource StepButtonStyle}" Tag="100"/>
                    <Button Click="QuickStep_Click" Content="+500" Style="{StaticResource StepButtonStyle}" Tag="500"/>
                </StackPanel>

            </StackPanel>

            <Border Grid.Row="1"
                    CornerRadius="0,0,8,8"
                    Padding="24,0"
                    Margin="0,0,0,12">
                <Grid>
                    <Button Content="重置"
                            HorizontalAlignment="Left"
                            Background="#40FFFFFF"
                            Foreground="White"
                            Style="{StaticResource DialogButtonStyle}"
                            Click="ResetButton_Click"/>
                    <Button Content="确定"
                            HorizontalAlignment="Right"
                            Background="#0078D7"
                            Foreground="White"
                            Style="{StaticResource DialogButtonStyle}"
                            IsDefault="True"
                            Click="OkButton_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
