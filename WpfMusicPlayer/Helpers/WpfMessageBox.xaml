<Window x:Class="WpfMusicPlayer.Helpers.WpfMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        SizeToContent="WidthAndHeight"
        MinWidth="340" MaxWidth="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="24" CornerRadius="8" Background="#E6202020"
            BorderBrush="#40FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Direction="270" Color="Black" Opacity="0.6"/>
        </Border.Effect>

        <Grid MinHeight="160">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="24,24,24,16">
                <TextBlock x:Name="IconText"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="28"
                           Foreground="#0078D7"
                           Margin="0,0,0,16"
                           Visibility="Collapsed"/>

                <TextBlock x:Name="TitleText"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="White"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>

                <TextBlock x:Name="MessageText"
                           FontSize="14"
                           Foreground="#CCCCCC"
                           TextWrapping="Wrap"
                           LineHeight="22"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="#18FFFFFF"
                    CornerRadius="0,0,8,8"
                    Padding="24,16">
                <!-- 更换OKButton为面板，方便添加更多按钮 -->
                <StackPanel x:Name="ButtonPanel" Orientation="Horizontal" HorizontalAlignment="Right"/>
            </Border>
        </Grid>
    </Border>
</Window>

