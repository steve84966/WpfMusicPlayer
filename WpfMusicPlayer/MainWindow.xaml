<Window x:Class="WpfMusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WpfMusicPlayer.ViewModels"
        xmlns:helpers="clr-namespace:WpfMusicPlayer.Helpers"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="WpfMusicPlayer" Height="600" Width="800"
        Background="Transparent"
        AllowDrop="True"
        MinWidth="400" MinHeight="450"
        Drop="MainWindow_Drop"
        Closed="MainWindow_Closed"
        SizeChanged="MainWindow_SizeChanged">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      GlassFrameThickness="-1"
                      ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <helpers:KaraokeClipConverter x:Key="KaraokeClipConverter"/>

        <!-- Dark-theme scrollbar for lyrics area -->
        <Style x:Key="LyricsScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="#40FFFFFF" CornerRadius="3"
                                Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#60FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#80FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LyricsScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource LyricsScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LyricsScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       HorizontalAlignment="Right"
                                       Orientation="Vertical"
                                       Style="{StaticResource LyricsScrollBarStyle}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarMenuItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                Margin="4,2"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="LyricItemTemplate" DataType="{x:Type vm:LyricLineViewModel}">
            <StackPanel Margin="0,8">
                <Grid>
                    <!-- Base lyric text -->
                    <TextBlock Text="{Binding Text}" TextAlignment="Center" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#88DDDDDD"/>
                                <Setter Property="FontSize" Value="16"/>
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="FontSize"
                                                                     To="22" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="FontSize"
                                                                     To="16" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                    <!-- When karaoke is active, dim the base so the white overlay stands out -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsHighlighted}" Value="True"/>
                                            <Condition Binding="{Binding IsProgressEnabled}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Foreground" Value="#AADDDDDD"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Karaoke white overlay – clipped to the played portion (sub-character precision) -->
                    <TextBlock Text="{Binding Text}" TextAlignment="Center" TextWrapping="Wrap"
                               Foreground="White" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="16"/>
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsHighlighted}" Value="True"/>
                                            <Condition Binding="{Binding IsProgressEnabled}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Clip">
                                            <Setter.Value>
                                                <MultiBinding Converter="{StaticResource KaraokeClipConverter}">
                                                    <Binding Path="Progress"/>
                                                    <Binding Path="Text"/>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource Self}"/>
                                                    <Binding Path="FontSize" RelativeSource="{RelativeSource Self}"/>
                                                    <Binding Path="FontWeight" RelativeSource="{RelativeSource Self}"/>
                                                    <Binding RelativeSource="{RelativeSource Self}"/>
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                    </MultiDataTrigger>
                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="FontSize"
                                                                     To="22" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="FontSize"
                                                                     To="16" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <TextBlock Text="{Binding Translation}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#66DDDDDD"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasTranslation}" Value="True"/>
                                        <Condition Binding="{Binding DataContext.IsTranslationVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                    <Setter Property="Foreground" Value="#BBDDDDDD"/>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="FontSize"
                                                                 To="15" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="FontSize"
                                                                 To="13" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Button
            Content="☰"
                WindowChrome.IsHitTestVisibleInChrome="True"
                VerticalAlignment="Top" HorizontalAlignment="Left"
                Width="46" Height="32"
                Background="Transparent" Foreground="White"
                BorderThickness="0" FontSize="16" FontFamily="Segoe MDL2 Assets"
                Click="MenuButton_Click"
                Panel.ZIndex="100">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="Transparent">
                                    <TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#20FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#30FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

        <Grid x:Name="ContentArea" Margin="0,32,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="120"/>
            </Grid.RowDefinitions>

            <!-- Landscape layout (width >= height) -->
            <Grid x:Name="LandscapeContent" Grid.Row="0" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border x:Name="LandscapeAlbumCover" Width="240" Height="240" CornerRadius="10"
                            Background="#444444" Margin="0,0,0,20" RenderTransformOrigin="0,0">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="LandscapeAlbumScale"/>
                                <TranslateTransform x:Name="LandscapeAlbumTranslate"/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Grid>
                            <TextBlock Text="Album Cover" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Image Stretch="UniformToFill" Source="{Binding AlbumCoverImage}"/>
                        </Grid>
                    </Border>
                    <StackPanel x:Name="LandscapeSongInfo">
                        <StackPanel.RenderTransform>
                            <TranslateTransform x:Name="LandscapeSongInfoTranslate"/>
                        </StackPanel.RenderTransform>
                        <Viewbox StretchDirection="DownOnly" MaxHeight="32" Margin="0,0,0,10">
                            <TextBlock Text="{Binding SongTitle}" Foreground="White" FontSize="24" FontWeight="Bold" TextWrapping="NoWrap"/>
                        </Viewbox>
                        <Viewbox StretchDirection="DownOnly" MaxHeight="22">
                            <TextBlock Text="{Binding ArtistName}" Foreground="#BBBBBB" FontSize="16" TextWrapping="NoWrap"/>
                        </Viewbox>
                    </StackPanel>
                </StackPanel>

                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto" Margin="20,0,0,0"
                              Style="{StaticResource LyricsScrollViewerStyle}">
                    <ScrollViewer.RenderTransform>
                        <TranslateTransform x:Name="LandscapeLyricsTranslate"/>
                    </ScrollViewer.RenderTransform>
                    <ListBox x:Name="LandscapeLyricsList" ItemsSource="{Binding Lyrics}" Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled"
                            PreviewMouseLeftButtonUp="LyricsList_PreviewMouseLeftButtonUp"
                            PreviewMouseWheel="LyricsList_PreviewMouseWheel"
                            ItemTemplate="{StaticResource LyricItemTemplate}">
                    </ListBox>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="PortraitContent" Grid.Row="0" Margin="20" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              Style="{StaticResource LyricsScrollViewerStyle}">
                    <ScrollViewer.RenderTransform>
                        <TranslateTransform x:Name="PortraitLyricsTranslate"/>
                    </ScrollViewer.RenderTransform>
                    <ListBox x:Name="PortraitLyricsList" ItemsSource="{Binding Lyrics}" Background="Transparent" BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             HorizontalAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             PreviewMouseLeftButtonUp="LyricsList_PreviewMouseLeftButtonUp"
                             PreviewMouseWheel="LyricsList_PreviewMouseWheel"
                             ItemTemplate="{StaticResource LyricItemTemplate}">
                    </ListBox>
                </ScrollViewer>

                <Grid Grid.Row="1" Margin="0,15,0,0" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="PortraitAlbumCover" Grid.Column="0" Width="120" Height="120"
                            CornerRadius="8" Background="#444444" RenderTransformOrigin="0,0">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="PortraitAlbumScale"/>
                                <TranslateTransform x:Name="PortraitAlbumTranslate"/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Grid>
                            <TextBlock Text="Album Cover" Foreground="#888888" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image Stretch="UniformToFill" Source="{Binding AlbumCoverImage}"/>
                        </Grid>
                    </Border>

                    <StackPanel x:Name="PortraitSongInfo" Grid.Column="1" VerticalAlignment="Bottom" Margin="15,0,0,0">
                        <StackPanel.RenderTransform>
                            <TranslateTransform x:Name="PortraitSongInfoTranslate"/>
                        </StackPanel.RenderTransform>
                        <Viewbox StretchDirection="DownOnly" MaxHeight="28" HorizontalAlignment="Left" Margin="0,0,0,6">
                            <TextBlock Text="{Binding SongTitle}" Foreground="White" FontSize="22" FontWeight="Bold" TextWrapping="NoWrap"/>
                        </Viewbox>
                        <Viewbox StretchDirection="DownOnly" MaxHeight="20" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding ArtistName}" Foreground="#BBBBBB" FontSize="14" TextWrapping="NoWrap"/>
                        </Viewbox>
                    </StackPanel>
                </Grid>
            </Grid>

            <Border Grid.Row="1" Background="#66333333" Padding="20,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding CurrentTime}" Foreground="#DDDDDD" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="{Binding ProgressMaximum}" Value="{Binding ProgressValue, Mode=TwoWay}" VerticalAlignment="Center"
                                PreviewMouseDown="ProgressSlider_PreviewMouseDown" PreviewMouseUp="ProgressSlider_PreviewMouseUp"/>
                        <TextBlock Grid.Column="2" Text="{Binding TotalTime}" Foreground="#DDDDDD" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="OpenButton" Grid.Column="0" Command="{Binding OpenCommand}" Content="&#x1F4C2; Open" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="16" Foreground="White" Background="#444444" Padding="15,8" BorderThickness="0" Cursor="Hand" Margin="10,0,0,0"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button Command="{Binding PlayModeCommand}" Content="🔀" FontSize="24" Margin="10,0" Width="50" Height="50" Background="Transparent" Foreground="White" BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <TextBlock Text="&#x1F500;" FontSize="24" Foreground="{TemplateBinding Foreground}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#20FFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#30FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding PrevCommand}" Content="&#x23EE;" FontSize="24" Margin="10,0" Width="50" Height="50" Background="Transparent" Foreground="White" BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <TextBlock Text="&#x23EE;" FontSize="24" Foreground="{TemplateBinding Foreground}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#20FFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#30FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding PlayPauseCommand}" Content="{Binding PlayPauseContent}" FontSize="28" Margin="10,0" Width="60" Height="60" Background="#0078D7" Foreground="White" BorderThickness="0" >
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <TextBlock Text="{TemplateBinding Content}" FontSize="{TemplateBinding FontSize}" Foreground="{TemplateBinding Foreground}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#20FFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#30FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding NextCommand}" Content="&#x23ED;" FontSize="24" Margin="10,0" Width="50" Height="50" Background="Transparent" Foreground="White" BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <TextBlock Text="&#x23ED;" FontSize="24" Foreground="{TemplateBinding Foreground}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#20FFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#30FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding TranslateCommand}" FontSize="24" Margin="10,0" Width="50" Height="50" BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <TextBlock x:Name="BtnText" Text="译" FontSize="24" Foreground="{TemplateBinding Foreground}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#20FFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#30FFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="BtnText" Property="Foreground" Value="#40FFFFFF"/>
                                                            <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTranslationVisible}" Value="True">
                                                <Setter Property="Background" Value="#330078D7"/>
                                                <Setter Property="Foreground" Value="#0078D7"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <StackPanel x:Name="VolumePanel" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="&#x1F50A;" FontSize="20" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Slider Width="100" Minimum="0" Maximum="1" Value="{Binding Volume, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="SidebarOverlay" Visibility="Collapsed" Panel.ZIndex="200">
            <Border x:Name="SidebarBackdrop" Background="#80000000" Opacity="0"
                    MouseLeftButtonDown="SidebarBackdrop_MouseLeftButtonDown"/>

            <Border
                HorizontalAlignment="Left" Width="280"
                    Background="#E6202020"
                    BorderBrush="#40FFFFFF" BorderThickness="0,0,1,0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="SidebarTranslate" X="-280"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="0" Color="Black" Opacity="0.5"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="#0078D7" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="WpfMusicPlayer" Foreground="White" FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="1" Height="1" Background="#30FFFFFF" Margin="12,0"/>

                    <ListBox Grid.Row="2" Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource SidebarMenuItemStyle}"
                             SelectionChanged="SidebarMenu_SelectionChanged"
                             x:Name="SidebarMenuList"
                             Margin="0,8,0,0">
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           VerticalAlignment="Center" Margin="0,0,14,0" Foreground="White"/>
                                <TextBlock Text="打开文件" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           VerticalAlignment="Center" Margin="0,0,14,0" Foreground="White"/>
                                <TextBlock Text="播放列表" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           VerticalAlignment="Center" Margin="0,0,14,0" Foreground="White"/>
                                <TextBlock Text="设置" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>

                    <StackPanel Grid.Row="3" Margin="0,0,0,8">
                        <Border Height="1" Background="#30FFFFFF" Margin="12,0,12,8"/>
                        <ListBox Background="Transparent" BorderThickness="0"
                                 ItemContainerStyle="{StaticResource SidebarMenuItemStyle}"
                                 SelectionChanged="SidebarMenuBottom_SelectionChanged"
                                 x:Name="SidebarMenuBottomList">
                            <ListBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               VerticalAlignment="Center" Margin="0,0,14,0" Foreground="White"/>
                                    <TextBlock Text="关于 WpfMusicPlayer..." VerticalAlignment="Center" Foreground="White"/>
                                </StackPanel>
                            </ListBoxItem>
                        </ListBox>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
