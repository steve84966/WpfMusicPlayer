<Window x:Class="WpfMusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WpfMusicPlayer.ViewModels"
        xmlns:views="clr-namespace:WpfMusicPlayer.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="WpfMusicPlayer" Height="600" Width="800"
        Icon="pack://application:,,,/Assets/ApplicationIcon.ico"
        Background="Transparent"
        AllowDrop="True"
        MinWidth="400" MinHeight="450"
        Drop="MainWindow_Drop"
        Closed="MainWindow_Closed"
        SizeChanged="MainWindow_SizeChanged">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      GlassFrameThickness="-1"
                      ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- 拆分面板组件为UserControl，避免God File问题-->
        <Style x:Key="SidebarMenuItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                Margin="4,2"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border VerticalAlignment="Center"
                Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                IsHitTestVisible="False"
                Panel.ZIndex="-1" ClipToBounds="True">
            <Border.OpacityMask>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="Transparent" Offset="0.0"/>
                    <GradientStop Color="#99FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#CCFFFFFF" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.OpacityMask>
            <Image Source="{Binding AlbumCoverImage}" Stretch="UniformToFill" Opacity="0.8"
                   Margin="-100" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image.Effect>
                    <BlurEffect Radius="80" KernelType="Gaussian"/>
                </Image.Effect>
            </Image>
        </Border>

        <Button
            Content="☰"
                WindowChrome.IsHitTestVisibleInChrome="True"
                VerticalAlignment="Top" HorizontalAlignment="Left"
                Width="46" Height="32"
                Background="Transparent" Foreground="White"
                BorderThickness="0" FontSize="16" FontFamily="Segoe MDL2 Assets"
                Click="MenuButton_Click"
                Panel.ZIndex="100">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="Transparent">
                                    <TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#20FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#30FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

        <Grid x:Name="ContentArea" Margin="0,32,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="120"/>
            </Grid.RowDefinitions>

            <!-- Landscape layout (width >= height) -->
            <Grid x:Name="LandscapeContent" Grid.Row="0" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border x:Name="LandscapeAlbumCover" Width="240" Height="240" CornerRadius="10"
                            Background="#444444" Margin="0,0,0,20" RenderTransformOrigin="0,0">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="LandscapeAlbumScale"/>
                                <TranslateTransform x:Name="LandscapeAlbumTranslate"/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Grid>
                            <TextBlock Text="Album Cover" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Image Stretch="UniformToFill" Source="{Binding AlbumCoverImage}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <views:LyricsView x:Name="LandscapeLyricsView" Grid.Column="1" Margin="20,0,0,0"
                                   ButtonOrientation="Horizontal"/>
            </Grid>

            <views:PlaylistView x:Name="PlaylistContent" Grid.Row="0" Visibility="Collapsed">
                <views:PlaylistView.RenderTransform>
                    <TranslateTransform/>
                </views:PlaylistView.RenderTransform>
            </views:PlaylistView>

            <Grid x:Name="PortraitContent" Grid.Row="0" Margin="20" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <views:LyricsView x:Name="PortraitLyricsView" Grid.Row="0"
                                   ButtonOrientation="Vertical"/>

                <Grid Grid.Row="1" Margin="0,15,0,0" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="PortraitAlbumCover" Grid.Column="0" Width="120" Height="120"
                            CornerRadius="8" Background="#444444" RenderTransformOrigin="0,0">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="PortraitAlbumScale"/>
                                <TranslateTransform x:Name="PortraitAlbumTranslate"/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Grid>
                            <TextBlock Text="Album Cover" Foreground="#888888" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image Stretch="UniformToFill" Source="{Binding AlbumCoverImage}"/>
                        </Grid>
                    </Border>

                    <views:SongInfoView x:Name="PortraitSongInfoView" Grid.Column="1" VerticalAlignment="Bottom" Margin="15,0,0,0"
                                        TitleFontSize="22" TitleMaxHeight="28" TitleBottomMargin="0,0,0,6" ArtistMaxHeight="20">
                        <views:SongInfoView.RenderTransform>
                            <TranslateTransform/>
                        </views:SongInfoView.RenderTransform>
                    </views:SongInfoView>
                </Grid>
            </Grid>

            <views:PlayerToolbarView x:Name="PlayerToolbar" Grid.Row="1"/>
        </Grid>

        <Grid x:Name="EqualizerOverlay" Visibility="Collapsed" Panel.ZIndex="150">
            <Border x:Name="EqualizerBackdrop" Background="#80000000" Opacity="0"
                    MouseLeftButtonDown="EqualizerBackdrop_MouseLeftButtonDown"/>
            <Border HorizontalAlignment="Right" Width="320"
                    Background="#E6202020" BorderBrush="#40FFFFFF" BorderThickness="1,0,0,0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="EqualizerTranslate" X="320"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="-4" Direction="180" Color="Black" Opacity="0.5"/>
                </Border.Effect>
                <views:EqualizerView DataContext="{Binding Equalizer}"/>
            </Border>
        </Grid>

        <Grid x:Name="SidebarOverlay" Visibility="Collapsed" Panel.ZIndex="200">
            <Border x:Name="SidebarBackdrop" Background="#80000000" Opacity="0"
                    MouseLeftButtonDown="SidebarBackdrop_MouseLeftButtonDown"/>

            <Border
                HorizontalAlignment="Left" Width="280"
                    Background="#E6202020"
                    BorderBrush="#40FFFFFF" BorderThickness="0,0,1,0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="SidebarTranslate" X="-280"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="0" Color="Black" Opacity="0.5"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="#0078D7" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="WpfMusicPlayer" Foreground="White" FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="1" Height="1" Background="#30FFFFFF" Margin="12,0"/>

                    <ListBox Grid.Row="2" Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource SidebarMenuItemStyle}"
                             SelectionChanged="SidebarMenu_SelectionChanged"
                             x:Name="SidebarMenuList"
                             Margin="0,8,0,0">
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           VerticalAlignment="Center" Margin="0,0,14,0" Foreground="White"/>
                                <TextBlock Text="打开文件" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           VerticalAlignment="Center" Margin="0,0,14,0" Foreground="White"/>
                                <TextBlock Text="播放列表" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9E9;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           VerticalAlignment="Center" Margin="0,0,14,0" Foreground="White"/>
                                <TextBlock Text="均衡器" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           VerticalAlignment="Center" Margin="0,0,14,0" Foreground="White"/>
                                <TextBlock Text="设置" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>

                    <StackPanel Grid.Row="3" Margin="0,0,0,8">
                        <Border Height="1" Background="#30FFFFFF" Margin="12,0,12,8"/>
                        <ListBox Background="Transparent" BorderThickness="0"
                                 ItemContainerStyle="{StaticResource SidebarMenuItemStyle}"
                                 SelectionChanged="SidebarMenuBottom_SelectionChanged"
                                 x:Name="SidebarMenuBottomList">
                            <ListBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               VerticalAlignment="Center" Margin="0,0,14,0" Foreground="White"/>
                                    <TextBlock Text="关于 WpfMusicPlayer..." VerticalAlignment="Center" Foreground="White"/>
                                </StackPanel>
                            </ListBoxItem>
                        </ListBox>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
